# ─────────────────────────────────────────────────────────────────────────────
# CANSLIM Screener Pro — API Keys
# Place this file in your project root: C:\Users\abend\CLAUDEBOX\PROJECTS\CANSLIMPRO\
# Fill in values after the = sign. No quotes needed.
# ─────────────────────────────────────────────────────────────────────────────

# Financial Modeling Prep (FMP)
# Used for: US fundamentals (EPS, revenue, institutional holders)
# Fallback: yFinance (auto-used for Indian stocks and when FMP is unavailable)
# Sign up: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Alpaca Markets — Data API
# Used for: US stock price bars, OHLCV history, latest quotes
# Fallback: yFinance (used automatically if Alpaca keys are absent)
# Get both from: https://app.alpaca.markets → API Keys section
# Free tier (IEX feed) is sufficient. No funded account required.
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
